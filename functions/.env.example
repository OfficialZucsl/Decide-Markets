# Gemini
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.0-flash

# Cron HTTP auth (required in production)
CRON_SECRET=generate_a_long_random_secret

# Firebase Admin (service account)
FIREBASE_PROJECT_ID=gen-lang-client-0283169058
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@gen-lang-client-0283169058.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Named Firestore database (matches firebase-applet-config.json)
FIRESTORE_DATABASE_ID=ai-studio-7d3feeba-1d1d-4a80-aebb-ce505e969c62

# Optional RSS overrides
DIGGERS_RSS_URL=https://diggers.news/feed
MONITOR_RSS_URL=

# Facebook pages (comma-separated public profile URLs)
FACEBOOK_PAGE_URLS=https://facebook.com/MwebantuZM,https://facebook.com/ZambianWatchdog,https://facebook.com/DiggersNewsZambia

# Twitter API v2 (free tier ~1500 requests/month)
TWITTER_BEARER_TOKEN=your_twitter_bearer_token
TWITTER_SEARCH_HASHTAGS=#Zambia,#Lusaka,#ZambiaNews,#ZambianEconomy

# Local Puppeteer (Windows/Mac dev)
CHROME_EXECUTABLE_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe

# Cloud Function region
FUNCTION_REGION=europe-west1
